; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DepthCraft"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

LocaleManager="*res://scripts/localization/locale_manager.gd"
BuildingData="*res://scripts/building/building_data.gd"
ItemDatabase="*res://scripts/inventory/item_database.gd"
TalentData="*res://scripts/talent/talent_data.gd"
NetworkManager="*res://scripts/network/network_manager.gd"
ClassSystem="*res://scripts/systems/class_system.gd"
SkillSystem="*res://scripts/skills/skill_system.gd"
AchievementManager="*res://scripts/systems/achievement_manager.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"
QuestManager="*res://scripts/systems/quest_manager.gd"
SaveManager="*res://scripts/systems/save_manager.gd"
WorldLevel="*res://scripts/systems/world_level.gd"
NpcManager="*res://scripts/world/npc_manager.gd"
CycleManager="*res://scripts/systems/cycle_manager.gd"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

